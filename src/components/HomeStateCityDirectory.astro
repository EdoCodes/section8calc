---
import { placesMetaInfo, states } from '../lib/places';
import { citiesPath, statePath, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
  title: string;
  filterLabel: string;
  filterPlaceholder: string;
  viewAllLabel: string;
}

const { lang, title, filterLabel, filterPlaceholder, viewAllLabel } = Astro.props;
const sorted = [...states].sort((a, b) => a.name.localeCompare(b.name));
const locale = lang === 'es' ? 'es-US' : 'en-US';
---

<section class="container container--wide home-state-directory" id="browse-by-state">
  <h2 class="home-section-title">{title}</h2>
  <p class="home-state-directory__meta">
    {placesMetaInfo.totalPlaces.toLocaleString(locale)} {lang === 'es' ? 'ciudades y lugares en' : 'cities and places across'}{' '}
    {placesMetaInfo.stateCount} {lang === 'es' ? 'estados' : 'states'}.
  </p>

  <div class="home-state-directory__search">
    <label for="home-state-filter">{filterLabel}</label>
    <input
      id="home-state-filter"
      type="search"
      placeholder={filterPlaceholder}
      autocomplete="off"
      aria-controls="home-state-grid"
      enterkeyhint="search"
    />
  </div>

  <ul id="home-state-grid" class="state-grid state-grid--compact">
    {
      sorted.map((state) => (
        <li data-name={state.name.toLowerCase()} data-abbr={state.abbr.toLowerCase()}>
          <a href={statePath(lang, state.slug)}>
            <strong>{state.name}</strong>
            <span class="state-grid__abbr">{state.abbr}</span>
          </a>
        </li>
      ))
    }
  </ul>

  <p class="home-state-directory__more">
    <a href={citiesPath(lang)}>{viewAllLabel}</a>
  </p>
</section>

<script>
  const input = document.getElementById('home-state-filter') as HTMLInputElement | null;
  const grid = document.getElementById('home-state-grid');
  if (input && grid) {
    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      grid.querySelectorAll<HTMLLIElement>('li').forEach((li) => {
        const name = li.dataset.name ?? '';
        const abbr = li.dataset.abbr ?? '';
        const show = !q || name.includes(q) || abbr.includes(q);
        li.style.display = show ? '' : 'none';
      });
    });
  }
</script>

<style>
  .home-state-directory {
    padding-bottom: 4rem;
  }

  .home-state-directory__meta {
    color: var(--color-ink-muted);
    margin: -0.5rem 0 1.25rem;
  }

  .home-state-directory__search {
    margin-bottom: 1.25rem;
  }

  .home-state-directory__search label {
    display: block;
    font-weight: 600;
    margin-bottom: 0.35rem;
  }

  .home-state-directory__search input {
    width: 100%;
    max-width: 28rem;
    padding: 0.75rem 1rem;
    border: 2px solid var(--color-accent);
    border-radius: 10px;
    font-size: 1rem;
    background: var(--color-surface-elevated);
  }

  .home-state-directory__search input:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px var(--color-focus-ring);
  }

  .home-state-directory__more {
    margin: 1.25rem 0 0;
    font-weight: 600;
  }

  .home-state-directory__more a {
    text-decoration: none;
  }

  .home-state-directory__more a:hover {
    text-decoration: underline;
  }
</style>
