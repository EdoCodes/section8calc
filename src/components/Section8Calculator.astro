---
import '../styles/calculator.css';
import { getCalcStrings, type Lang } from '../lib/i18n';

interface Props {
  lang?: Lang;
}

const lang = Astro.props.lang ?? 'en';
const t = getCalcStrings(lang);
const locale = lang === 'es' ? 'es-US' : 'en-US';
---

<section class="calc-shell" id="section8-calculator" data-lang={lang}>
  <div class="container calc-layout">
    <div class="calc-panel">
      <div class="calc-panel__head">
        <h2>{t.title}</h2>
        <p>{t.subtitle}</p>
      </div>

      <div class="calc-steps" aria-hidden="true">
        <div class="calc-step-pill is-active">
          <span class="calc-step-num">1</span>
          {t.stepLocation}
        </div>
        <div class="calc-step-pill">
          <span class="calc-step-num">2</span>
          {t.stepHousehold}
        </div>
        <div class="calc-step-pill">
          <span class="calc-step-num">3</span>
          {t.stepResults}
        </div>
      </div>

      <form id="calc-form" class="calc-form-body" novalidate>
        <fieldset>
          <legend>{t.stepLocation}</legend>
          <div class="form-row cols-3">
            <div class="form-field">
              <label for="zip">{t.zip}</label>
              <input id="zip" name="zip" inputmode="numeric" pattern="\d{5}" maxlength="5" placeholder="80204" required />
              <small>{t.zipHint}</small>
            </div>
            <div class="form-field">
              <label for="city">{t.city}</label>
              <select id="city" name="city" disabled required>
                <option value="">{t.cityPlaceholder}</option>
              </select>
            </div>
            <div class="form-field">
              <label for="county">{t.county}</label>
              <select id="county" name="county" disabled required>
                <option value="">{t.cityPlaceholder}</option>
              </select>
            </div>
          </div>
          <p id="location-status" class="calc-status hidden" role="status"></p>
        </fieldset>

        <fieldset>
          <legend>{t.householdLegend}</legend>
          <div class="form-row cols-2">
            <div class="form-field">
              <label for="householdSize">{t.householdSize}</label>
              <select id="householdSize" name="householdSize" required>
                {[1, 2, 3, 4, 5, 6, 7, 8].map((n) => (
                  <option value={n} selected={n === 3}>
                    {n} {n === 1 ? t.person : t.people}
                  </option>
                ))}
              </select>
            </div>
            <div class="form-field">
              <label for="bedrooms">{t.bedrooms}</label>
              <select id="bedrooms" name="bedrooms" required>
                <option value="0">{t.studio}</option>
                <option value="1">1 {t.br}</option>
                <option value="2" selected>2 {t.br}</option>
                <option value="3">3 {t.br}</option>
                <option value="4">4 {t.br}</option>
              </select>
            </div>
          </div>
          <div class="form-row cols-2">
            <div class="form-field">
              <label for="annualGrossIncome">{t.annualIncome} ($)</label>
              <input id="annualGrossIncome" name="annualGrossIncome" type="number" min="0" step="100" placeholder="28000" required />
            </div>
            <div class="form-field">
              <label for="annualDeductions">{t.deductions} ($) <small>({t.optional})</small></label>
              <input id="annualDeductions" name="annualDeductions" type="number" min="0" step="100" placeholder="0" />
              <small>{t.deductionsHint}</small>
            </div>
          </div>
          <div class="form-field">
            <label for="monthlyRent">{t.monthlyRent} ($) <small>({t.optional})</small></label>
            <input id="monthlyRent" name="monthlyRent" type="number" min="0" step="50" placeholder="1400" />
            <small>{t.monthlyRentHint}</small>
          </div>
        </fieldset>

        <button type="submit" class="btn btn-primary calc-submit" id="calc-submit">{t.submit}</button>
      </form>
    </div>

    <aside class="calc-results-sidebar" aria-live="polite">
      <h3>{t.resultsTitle}</h3>
      <div id="calc-results-placeholder">
        <div class="placeholder-icon" aria-hidden="true">📊</div>
        <p class="placeholder">{t.resultsPlaceholder}</p>
      </div>
      <div id="calc-results" class="hidden"></div>
    </aside>
  </div>
</section>

<script define:vars={{ t, locale, lang }}>
  import { trackEvent } from '../lib/analytics';

  const form = document.getElementById('calc-form');
  const zipInput = document.getElementById('zip');
  const citySelect = document.getElementById('city');
  const countySelect = document.getElementById('county');
  const statusEl = document.getElementById('location-status');
  const resultsEl = document.getElementById('calc-results');
  const placeholderEl = document.getElementById('calc-results-placeholder');
  const submitBtn = document.getElementById('calc-submit');

  const labels = {
    eligible: t.eligible,
    possibly_eligible: t.possiblyEligible,
    not_eligible: t.notEligible,
  };

  let lookupCache = null;
  let zipDebounce;
  let lastTrackedZip = '';

  trackEvent('calculator_view', { page_path: window.location.pathname, lang });

  const zipFromUrl = new URLSearchParams(window.location.search).get('zip')?.replace(/\D/g, '').slice(0, 5);
  if (zipFromUrl && zipFromUrl.length === 5) {
    zipInput.value = zipFromUrl;
    lookupZipCode(zipFromUrl).catch((e) => setStatus(e.message, true, true));
  }

  function formatMoney(n) {
    return new Intl.NumberFormat(locale, { style: 'currency', currency: 'USD', maximumFractionDigits: 0 }).format(n);
  }

  function setStatus(msg, visible = true, isError = false) {
    statusEl.textContent = msg;
    statusEl.classList.toggle('hidden', !visible);
    statusEl.classList.toggle('is-error', isError);
  }

  function showResults() {
    placeholderEl.classList.add('hidden');
    resultsEl.classList.remove('hidden');
  }

  function fillLocation(data) {
    lookupCache = data;
    citySelect.innerHTML = '';
    countySelect.innerHTML = '';

    for (const p of data.places) {
      const opt = document.createElement('option');
      opt.value = p.city;
      opt.textContent = `${p.city}, ${p.stateAbbr}`;
      opt.dataset.stateAbbr = p.stateAbbr;
      citySelect.appendChild(opt);
    }

    for (const c of data.counties) {
      const opt = document.createElement('option');
      opt.value = c.entityId;
      opt.textContent = c.name;
      opt.dataset.countyName = c.name;
      countySelect.appendChild(opt);
    }

    citySelect.disabled = false;
    countySelect.disabled = false;
    setStatus(t.locationFound(data.places.length, data.counties.length, data.zip));

    if (data.zip !== lastTrackedZip) {
      lastTrackedZip = data.zip;
      trackEvent('zip_lookup_success', {
        zip: data.zip,
        state: data.places[0]?.stateAbbr ?? '',
        place_count: data.places.length,
        county_count: data.counties.length,
      });
    }
  }

  async function lookupZipCode(zip) {
    setStatus(t.lookingUp);
    trackEvent('zip_lookup_started', { zip });
    const res = await fetch(`/api/location/zip?zip=${encodeURIComponent(zip)}`);
    const data = await res.json();
    if (!res.ok) {
      trackEvent('zip_lookup_error', { zip, error_message: data.error ?? 'failed' });
      throw new Error(data.error ?? t.noZip);
    }
    fillLocation(data);
  }

  zipInput.addEventListener('input', () => {
    const zip = zipInput.value.replace(/\D/g, '').slice(0, 5);
    zipInput.value = zip;
    lookupCache = null;
    if (zip.length !== 5) {
      citySelect.disabled = true;
      countySelect.disabled = true;
      setStatus('', false);
      return;
    }
    clearTimeout(zipDebounce);
    zipDebounce = setTimeout(() => lookupZipCode(zip).catch((e) => setStatus(e.message, true, true)), 400);
  });

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!lookupCache) {
      setStatus(t.zipFirst, true, true);
      trackEvent('calculate_blocked', { reason: 'no_zip_lookup' });
      return;
    }

    const countyOpt = countySelect.selectedOptions[0];
    const cityOpt = citySelect.selectedOptions[0];
    const monthlyRentInput = document.getElementById('monthlyRent');

    trackEvent('calculate_click', {
      zip: lookupCache.zip,
      state: cityOpt?.dataset.stateAbbr ?? '',
      household_size: Number(document.getElementById('householdSize').value),
      bedrooms: Number(document.getElementById('bedrooms').value),
      has_rent: Boolean(monthlyRentInput?.value),
    });

    submitBtn.disabled = true;
    form.classList.add('loading');
    resultsEl.classList.add('hidden');
    placeholderEl.classList.remove('hidden');

    try {
      const res = await fetch('/api/calculate', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          zip: lookupCache.zip,
          city: cityOpt?.value,
          county: countyOpt?.dataset.countyName,
          stateAbbr: cityOpt?.dataset.stateAbbr,
          entityId: countyOpt?.value,
          annualGrossIncome: Number(document.getElementById('annualGrossIncome').value),
          annualDeductions: Number(document.getElementById('annualDeductions').value) || 0,
          householdSize: Number(document.getElementById('householdSize').value),
          bedrooms: Number(document.getElementById('bedrooms').value),
          monthlyRent: monthlyRentInput?.value ? Number(monthlyRentInput.value) : undefined,
        }),
      });

      const data = await res.json();
      if (!res.ok) throw new Error(data.error ?? 'Calculation failed');

      const { eligibility, subsidy, incomeLimits, fmr, disclaimer } = data;
      const statusClass = eligibility.status;
      const headline = labels[statusClass] ?? eligibility.label;

      let rentNote = '';
      if (subsidy.actualHap != null) {
        rentNote = `<p class="rent-note">${t.withRent(formatMoney(subsidy.actualHap))}</p>`;
        if (subsidy.rentAboveStandard) {
          rentNote += `<p class="warn">${t.rentAbove(formatMoney(subsidy.rentAboveStandard))}</p>`;
        }
      }

      resultsEl.dataset.status = statusClass;
      resultsEl.innerHTML = `
        <p class="result-headline">${headline}</p>
        <p class="result-area"><strong>${incomeLimits.areaName}</strong> (HUD ${incomeLimits.year}) — ${t.veryLowLimit}: <strong>${formatMoney(eligibility.veryLowLimit)}${t.perYear}</strong></p>
        <div class="stat-grid">
          <div class="stat"><p class="label">${t.yourShare}</p><p class="value">${formatMoney(subsidy.totalTenantPayment)}${t.perMonth}</p></div>
          <div class="stat"><p class="label">${t.paymentStandard} (${fmr.bedrooms} BR)</p><p class="value">${formatMoney(subsidy.paymentStandard)}${t.perMonth}</p></div>
          <div class="stat"><p class="label">${t.maxHelp}</p><p class="value">${formatMoney(subsidy.maxMonthlySubsidy)}${t.perMonth}</p></div>
          <div class="stat"><p class="label">${t.fmrBasis}</p><p class="value">${formatMoney(fmr.fmrAmount)}${t.perMonth}</p></div>
        </div>
        ${rentNote}
        <p><small>${disclaimer}</small></p>
      `;
      showResults();

      trackEvent('calculate_success', {
        zip: lookupCache.zip,
        state: cityOpt?.dataset.stateAbbr ?? '',
        eligibility: eligibility.status,
        max_subsidy: subsidy.maxMonthlySubsidy,
        ttp: subsidy.totalTenantPayment,
      });
    } catch (err) {
      const message = err instanceof Error ? err.message : 'Something went wrong.';
      trackEvent('calculate_error', { zip: lookupCache?.zip ?? '', error_message: message.slice(0, 120) });
      resultsEl.dataset.status = 'error';
      resultsEl.innerHTML = `<p class="result-headline">${message}</p>`;
      showResults();
    } finally {
      submitBtn.disabled = false;
      form.classList.remove('loading');
    }
  });
</script>

<style>
  .rent-note {
    margin: 0.75rem 0 0;
    font-size: 0.92rem;
  }
  .warn {
    color: var(--color-warning);
    font-size: 0.9rem;
  }
</style>
