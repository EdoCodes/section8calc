---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Section8Directory from '../../../components/Section8Directory.astro';
import { placesMetaInfo, states } from '../../../lib/places';
import { citiesPath, getSection8IndexStrings, statePath } from '../../../lib/i18n';

const s = getSection8IndexStrings('es');
const count = placesMetaInfo.totalPlaces.toLocaleString('es-US');
const sorted = [...states].sort((a, b) => a.name.localeCompare(b.name));

const breadcrumbLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://section8calculator.netlify.app/es/' },
    { '@type': 'ListItem', position: 2, name: 'Section 8 por estado' },
  ],
};

const itemListLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Section 8 por estado',
  numberOfItems: sorted.length,
  itemListElement: sorted.map((state, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: `${state.name} (${state.abbr})`,
    url: `https://section8calculator.netlify.app${statePath('es', state.slug)}`,
  })),
};
---

<BaseLayout
  title={s.title}
  description={s.description(count)}
  canonicalPath={citiesPath('es')}
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLd)} />
    <script type="application/ld+json" set:html={JSON.stringify(itemListLd)} />
  </Fragment>
  <Section8Directory lang="es" />
</BaseLayout>
