---
import BlogArticleLayout, { type BlogTocItem } from '../../components/BlogArticleLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('blog', 'section-8-chicago-neighborhoods-programs');
if (!entry) throw new Error('Blog entry section-8-chicago-neighborhoods-programs not found');

const { Content } = await render(entry);
const { title, description, pubDate, tags, image } = entry.data;

const slugPath = '/blog/section-8-chicago-neighborhoods-programs';
const site = Astro.site?.href?.replace(/\/$/, '') ?? 'https://section8calculator.com';
const pageUrl = `${site}${slugPath}`;

const publishDate = pubDate.toISOString().slice(0, 10);
const updatedDate = entry.data.updatedDate
  ? entry.data.updatedDate.toISOString().slice(0, 10)
  : publishDate;

const wordCount = (entry.body ?? '').trim().split(/\s+/).filter(Boolean).length;
const readingTime = `${Math.max(1, Math.ceil(wordCount / 200))} min read`;

const tocItems: BlogTocItem[] = [
  { href: '#how-big-is-chicagos-section-8-program', label: "Chicago's Section 8 program" },
  { href: '#where-section-8-vouchers-are-concentrated-in-chicago', label: 'Where vouchers are concentrated' },
  { href: '#why-section-8-vouchers-cluster-in-certain-chicago-neighborhoods', label: 'Why vouchers cluster' },
  { href: '#how-chicagos-housing-choice-voucher-program-works', label: 'How the HCV program works' },
  { href: '#mobility-counseling-helping-section-8-tenants-reach-opportunity-areas', label: 'Mobility counseling' },
  { href: '#beyond-section-8-other-affordable-housing-and-rental-assistance-in-chicago', label: 'Other housing resources' },
  { href: '#people-also-ask-section-8-in-chicago', label: 'People also ask' },
  { href: '#faqs-using-section-8-and-finding-resources-in-chicago', label: 'FAQs' },
  { href: '#sources', label: 'Sources' },
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: 'Section 8 in Chicago: Voucher Hotspots, Mobility Programs, and Affordable Housing Resources in 2026',
  description,
  image: image ? [`${site}${image}`] : [],
  datePublished: publishDate,
  dateModified: updatedDate,
  author: {
    '@type': 'Organization',
    name: 'Section 8 Calculator',
    url: site,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Section 8 Calculator',
    url: site,
    logo: { '@type': 'ImageObject', url: `${site}/favicon.svg` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Which neighborhoods in Chicago have the most Section 8 voucher holders?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'South Shore and Austin each had over 3,000 voucher households — more than the combined total of all 19 majority-white communities. Vouchers are heavily concentrated in majority-Black South and West Side neighborhoods including West Garfield Park, North Lawndale, and Englewood.',
      },
    },
    {
      '@type': 'Question',
      name: "Why aren't more Section 8 vouchers used on the North Side or downtown Chicago?",
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'North Side and downtown neighborhoods have higher rents, fewer voucher-sized units, and landlords less familiar with the program, making it harder to find units within voucher payment caps. Source-of-income discrimination also plays a role.',
      },
    },
    {
      '@type': 'Question',
      name: 'How many families does the Chicago Housing Choice Voucher program serve?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: "CHA's HCV program serves more than 47,000 families across Chicago, with authorization for just over 54,000 units, making it one of the largest city-level voucher programs in the country.",
      },
    },
    {
      '@type': 'Question',
      name: 'Who qualifies for Section 8 in Chicago?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Households must be very low income (below 50% of AMI), with a large share targeted to those below 30% AMI. At least one member must have eligible citizenship or immigration status, and applicants must pass screening.',
      },
    },
    {
      '@type': 'Question',
      name: 'Are there incentives for landlords to accept Section 8 in Chicago?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Yes. CHA offers a one-time Landlord Incentive Payment equal to one month of contract rent for new owners in mobility areas, vacancy payments of up to two months, and accessibility modifications at no cost to the owner.',
      },
    },
    {
      '@type': 'Question',
      name: 'How does the Mobility Counseling Program help voucher families in Chicago?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'CHA partners with Housing Choice Partners to help voucher families move to Mobility Areas — community areas with poverty rates under 20% and below-median crime. Families get workshops, one-on-one counseling, unit search help, and post-move support.',
      },
    },
    {
      '@type': 'Question',
      name: 'What other affordable housing resources are available in Chicago besides Section 8?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Chicago Low-Income Housing Trust Fund rental subsidies, DOH-financed LIHTC developments, emergency rental assistance (ERAP and nonprofit programs like Solid Ground), and supportive housing funded by DOH, CHA, and state partners.',
      },
    },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${site}/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${site}/blog/` },
    { '@type': 'ListItem', position: 3, name: 'Section 8 in Chicago', item: pageUrl },
  ],
};
---

<BlogArticleLayout
  title={title}
  description={description}
  canonical={slugPath}
  lang="en"
  author="Section 8 Calculator Team"
  authorTitle="Editorial"
  readingTime={readingTime}
  updatedDate={updatedDate}
  tags={tags}
  heroImage={image}
  tocItems={tocItems}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />
  <Content />
</BlogArticleLayout>
