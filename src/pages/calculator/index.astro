---
import BaseLayout from '../../layouts/BaseLayout.astro';
import CalcHowItWorks from '../../components/CalcHowItWorks.astro';
import CalculatorHero from '../../components/CalculatorHero.astro';
import Section8Calculator from '../../components/Section8Calculator.astro';
import { calcPath } from '../../lib/i18n';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Section 8 Housing Calculator',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description:
    'Estimate Section 8 Housing Choice Voucher eligibility and monthly assistance by ZIP, city, county, and household income.',
};
---

<BaseLayout
  title="Section 8 Calculator by ZIP — Eligibility & Rent Estimate"
  description="Use our Section 8 calculator: enter ZIP to confirm city and county, then estimate voucher eligibility, income limits, and monthly housing assistance."
  canonicalPath={calcPath('en')}
  lang="en"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <div class="calc-page-wide">
    <CalculatorHero lang="en" />
    <Section8Calculator lang="en" />
  </div>
  <CalcHowItWorks lang="en" />
</BaseLayout>

<style>
  .calc-page-wide :global(.calc-shell) {
    margin-top: -2rem;
  }
</style>
