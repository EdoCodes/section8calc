---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import CalcHowItWorks from '../../../components/CalcHowItWorks.astro';
import CalculatorHero from '../../../components/CalculatorHero.astro';
import Section8Calculator from '../../../components/Section8Calculator.astro';
import { calcPath } from '../../../lib/i18n';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Calculadora Section 8',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description:
    'Estime elegibilidad del voucher Housing Choice y ayuda mensual por ZIP, ciudad, condado e ingreso del hogar.',
  inLanguage: 'es',
};
---

<BaseLayout
  title="Calculadora Section 8 por ZIP — Elegibilidad y renta"
  description="Calculadora Section 8: ingrese ZIP, confirme ciudad y condado, y estime elegibilidad del voucher, límites HUD y ayuda mensual."
  canonicalPath={calcPath('es')}
  lang="es"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <div class="calc-page-wide">
    <CalculatorHero lang="es" />
    <Section8Calculator lang="es" />
  </div>
  <CalcHowItWorks lang="es" />
</BaseLayout>

<style>
  .calc-page-wide :global(.calc-shell) {
    margin-top: -2rem;
  }
</style>

