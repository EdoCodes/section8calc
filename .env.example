# Register at https://www.huduser.gov/hudapi/public/register
HUD_API_TOKEN=your_hud_bearer_token_here

# Google Analytics 4 (optional — for testing calculator funnel after deploy)
# Create at https://analytics.google.com/ → Admin → Data streams → Measurement ID (G-XXXXXXXX)
PUBLIC_GA_MEASUREMENT_ID=
# Set true to see events in GA4 DebugView while testing locally
PUBLIC_GA_DEBUG=false
