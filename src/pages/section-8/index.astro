---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section8Directory from '../../components/Section8Directory.astro';
import { placesMetaInfo } from '../../lib/places';
import { citiesPath, getSection8IndexStrings } from '../../lib/i18n';

const s = getSection8IndexStrings('en');
const count = placesMetaInfo.totalPlaces.toLocaleString('en-US');
---

<BaseLayout
  title={s.title}
  description={s.description(count)}
  canonicalPath={citiesPath('en')}
  lang="en"
>
  <Section8Directory lang="en" />
</BaseLayout>
