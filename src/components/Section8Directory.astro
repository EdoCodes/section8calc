---
import { placesMetaInfo, states } from '../lib/places';
import { calcPath, getSection8IndexStrings, statePath, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const s = getSection8IndexStrings(lang);
const sorted = [...states].sort((a, b) => a.name.localeCompare(b.name));
const count = placesMetaInfo.totalPlaces.toLocaleString(lang === 'es' ? 'es-US' : 'en-US');
---

<section class="page-hero">
  <div class="container">
    <h1 class="font-display">{s.h1}</h1>
    <p>{s.lead(count)}</p>
    <p style="margin-top: 1.25rem;">
      <a class="btn btn-primary" href={calcPath(lang)}>{s.cta}</a>
    </p>
  </div>
</section>

<section class="container s8-intro" style="padding-top: 2rem;">
  <h2>{s.subhead}</h2>
  {s.intro.map((p) => <p>{p}</p>)}
</section>

<section class="container" style="padding-bottom: 4rem;">
  <h2 class="home-section-title">{s.browseTitle}</h2>
  <p class="s8-directory-meta">
    {placesMetaInfo.totalPlaces.toLocaleString(lang === 'es' ? 'es-US' : 'en-US')}
    {lang === 'es' ? 'ciudades y lugares en' : 'cities and places across'}
    {' '}{placesMetaInfo.stateCount} {lang === 'es' ? 'estados' : 'states'}.
  </p>
  <ul class="state-grid state-grid--compact">
    {sorted.map((state) => (
      <li>
        <a href={statePath(lang, state.slug)}>
          <strong>{state.name}</strong>
          <span class="state-grid__abbr">{state.abbr}</span>
        </a>
      </li>
    ))}
  </ul>
  <p class="s8-directory-more">
    <a href={calcPath(lang)}>{s.viewAll}</a>
  </p>
</section>

<style>
  .s8-intro {
    max-width: 46rem;
  }

  .s8-intro h2 {
    font-size: 1.2rem;
    margin: 0 0 0.75rem;
    color: var(--color-ink);
  }

  .s8-intro p {
    color: var(--color-ink-muted);
    font-size: 0.98rem;
    line-height: 1.6;
    margin: 0 0 0.75rem;
  }

  .s8-directory-meta {
    font-size: 0.92rem;
    color: var(--color-ink-muted);
    margin: -0.35rem 0 1rem;
  }

  .s8-directory-more {
    margin-top: 1.25rem;
    font-weight: 600;
  }

  .s8-directory-more a {
    text-decoration: none;
  }

  .s8-directory-more a:hover {
    text-decoration: underline;
  }
</style>
