---
import BaseLayout from '../layouts/BaseLayout.astro';
import { blogPath, calcPath, type Lang } from '../lib/i18n';

export interface BlogTocItem {
  href: string;
  label: string;
}

interface Props {
  title: string;
  description: string;
  canonical: string;
  lang?: Lang;
  author?: string;
  authorTitle?: string;
  readingTime?: string;
  updatedDate?: string;
  tags?: string[];
  heroImage?: string;
  tocItems?: BlogTocItem[];
}

const {
  title,
  description,
  canonical,
  lang = 'en',
  author = 'Section 8 Calculator Team',
  authorTitle = 'Editorial',
  readingTime,
  updatedDate,
  tags = [],
  heroImage,
  tocItems = [],
} = Astro.props;

const authorParts = author.trim().split(/\s+/).filter(Boolean);
const authorInitials =
  authorParts.length >= 2
    ? (authorParts[0][0] + authorParts[1][0]).toUpperCase()
    : author.slice(0, 2).toUpperCase();

const blogHome = blogPath(lang);
const calcHome = calcPath(lang);
---

<BaseLayout title={title} description={description} canonicalPath={canonical} ogType="article" lang={lang}>
  <slot name="head" slot="head" />

  <div class="breadcrumb-bar">
    <div class="blog-container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href={lang === 'es' ? '/es/' : '/'}>Home</a>
        <span class="crumb-sep">›</span>
        <a href={blogHome}>Blog</a>
        <span class="crumb-sep">›</span>
        <span class="crumb-current">{title.length > 50 ? title.slice(0, 50) + '…' : title}</span>
      </nav>
    </div>
  </div>

  <header class="article-hero">
    {heroImage && (
      <div class="hero-image-wrap">
        <img src={heroImage} alt="" class="hero-image" />
        <div class="hero-overlay" />
      </div>
    )}
    <div class="blog-container hero-content">
      <div class="article-label">Blog</div>
      <h1>{title}</h1>
      <p class="article-subtitle">{description}</p>
      <div class="article-meta">
        {updatedDate && <span class="meta-item">Updated {updatedDate}</span>}
        {updatedDate && readingTime && <span class="meta-dot">·</span>}
        {readingTime && <span class="meta-item">{readingTime}</span>}
        {(updatedDate || readingTime) && author && <span class="meta-dot">·</span>}
        {author && <span class="meta-item">By {author}</span>}
      </div>
      {tags.length > 0 && (
        <div class="article-tags">
          {tags.map((tag) => (
            <span class="hero-tag">{tag}</span>
          ))}
        </div>
      )}
    </div>
  </header>

  <div class="article-layout">
    <div class="blog-container">
      <div class="article-body">
        <aside class="toc-sidebar">
          {tocItems.length > 0 && (
            <div class="toc-card">
              <div class="toc-title">Table of Contents</div>
              <ol class="toc-list">
                {tocItems.map((item) => (
                  <li>
                    <a href={item.href}>{item.label}</a>
                  </li>
                ))}
              </ol>
            </div>
          )}
          <div class="author-card">
            <div class="author-avatar">{authorInitials}</div>
            <div class="author-info">
              <div class="author-name">{author}</div>
              <div class="author-role">{authorTitle}</div>
            </div>
          </div>
          <div class="sidebar-cta">
            <p>Check your Section 8 eligibility</p>
            <a href={calcHome} class="sidebar-cta-btn">Section 8 Calculator →</a>
          </div>
        </aside>

        <article class="article-content prose">
          <slot />
        </article>
      </div>
    </div>
  </div>
</BaseLayout>

<style is:global>
  .breadcrumb-bar {
    background: var(--color-surface-elevated);
    border-bottom: 1px solid var(--color-border);
    padding: 0.75rem 0;
  }
  .blog-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-ink-muted);
    flex-wrap: wrap;
  }
  .crumb-sep { opacity: 0.5; }
  .breadcrumb a {
    color: var(--color-ink-muted);
    text-decoration: none;
  }
  .breadcrumb a:hover { color: var(--color-accent); }
  .crumb-current { color: var(--color-ink); font-weight: 500; }

  /* Hero */
  .article-hero {
    position: relative;
    background: linear-gradient(135deg, #002147 0%, #003366 60%, #004a8f 100%);
    color: white;
    padding: 3.5rem 0 3rem;
    text-align: center;
  }
  .hero-image-wrap {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }
  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.2;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,33,71,0.7) 0%, rgba(0,51,102,0.9) 100%);
  }
  .hero-content { position: relative; z-index: 1; }
  .article-label {
    display: inline-block;
    background: rgba(242,101,34,0.25);
    border: 1px solid rgba(242,101,34,0.45);
    color: #fff;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    padding: 0.35rem 0.9rem;
    border-radius: 20px;
    margin-bottom: 1.25rem;
  }
  .article-hero h1 {
    color: white;
    font-size: clamp(1.75rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.2;
    max-width: 780px;
    margin: 0 auto 1rem;
  }
  .article-subtitle {
    font-size: 1.0625rem;
    color: rgba(255,255,255,0.88);
    max-width: 640px;
    margin: 0 auto 1.25rem;
    line-height: 1.6;
  }
  .article-meta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.72);
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }
  .meta-dot { opacity: 0.5; }
  .article-tags {
    display: flex;
    gap: 0.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  .hero-tag {
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    color: rgba(255,255,255,0.92);
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.3rem 0.75rem;
    border-radius: 20px;
  }

  /* Two-column layout */
  .article-layout {
    padding: 3rem 0 5rem;
    background: var(--color-surface);
  }
  .article-body {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* TOC sidebar */
  .toc-sidebar { position: sticky; top: 80px; }
  .toc-card {
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.25rem;
    margin-bottom: 1.25rem;
  }
  .toc-title {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 0.875rem;
  }
  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 2px;
    counter-reset: toc;
  }
  .toc-list li {
    counter-increment: toc;
    position: relative;
  }
  .toc-list li::before {
    content: counter(toc) '.';
    position: absolute;
    left: 0;
    top: 0.35rem;
    font-size: 0.78rem;
    color: var(--color-border-strong);
    font-weight: 600;
    width: 1.25rem;
    text-align: right;
  }
  .toc-list a {
    display: block;
    padding: 0.35rem 0.5rem 0.35rem 1.5rem;
    font-size: 0.84rem;
    color: var(--color-ink-muted);
    text-decoration: none;
    border-radius: 6px;
    transition: background 0.12s, color 0.12s;
    line-height: 1.4;
  }
  .toc-list a:hover {
    background: var(--color-accent-muted);
    color: var(--color-accent);
  }

  /* Author card */
  .author-card {
    background: var(--color-surface-elevated);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 1.125rem;
    display: flex;
    align-items: center;
    gap: 0.875rem;
    margin-bottom: 1.25rem;
  }
  .author-avatar {
    width: 42px;
    height: 42px;
    background: linear-gradient(135deg, #002147, #004a8f);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .author-name {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-ink);
  }
  .author-role {
    font-size: 0.75rem;
    color: var(--color-ink-muted);
    margin-top: 2px;
  }

  /* Sidebar CTA */
  .sidebar-cta {
    background: var(--color-accent-muted);
    border: 1px solid rgba(242,101,34,0.25);
    border-radius: 10px;
    padding: 1.25rem;
    text-align: center;
  }
  .sidebar-cta p {
    font-size: 0.875rem;
    color: var(--color-ink);
    font-weight: 600;
    margin: 0 0 0.75rem;
  }
  .sidebar-cta-btn {
    display: inline-block;
    background: var(--color-accent);
    color: #fff !important;
    font-size: 0.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 9px 18px;
    border-radius: 6px;
    text-decoration: none !important;
    transition: background 0.15s;
  }
  .sidebar-cta-btn:hover {
    background: #d4551a;
  }

  /* Article content prose */
  .article-content {
    min-width: 0;
  }
  .article-content p {
    font-size: 1rem;
    color: var(--color-ink-muted);
    line-height: 1.85;
    margin-bottom: 1.35rem;
  }
  .article-content h2 {
    font-size: 1.55rem;
    font-weight: 800;
    color: var(--color-ink);
    letter-spacing: -0.02em;
    margin: 2.5rem 0 1.25rem;
    line-height: 1.3;
    scroll-margin-top: 5rem;
    transition: color 0.18s;
  }
  .article-content h2:hover { color: var(--color-accent); }
  .article-content h3 {
    font-size: 1.18rem;
    font-weight: 700;
    color: var(--color-ink);
    margin: 2rem 0 0.85rem;
    line-height: 1.35;
    scroll-margin-top: 5rem;
    transition: color 0.18s;
  }
  .article-content h3:hover { color: var(--color-accent); }
  .article-content h4 {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-ink);
    margin: 1.5rem 0 0.65rem;
    scroll-margin-top: 5rem;
  }
  .article-content a {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .article-content a:hover {
    color: #d4551a;
  }
  .article-content ul,
  .article-content ol {
    padding-left: 1.35rem;
    margin: 0 0 1.35rem;
    color: var(--color-ink-muted);
    line-height: 1.82;
  }
  .article-content li { margin-bottom: 0.5rem; }
  .article-content strong { color: var(--color-ink); }
  .article-content hr {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2.5rem 0;
  }
  .article-content blockquote {
    border-left: 4px solid var(--color-accent);
    background: var(--color-accent-muted);
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    border-radius: 0 8px 8px 0;
    color: var(--color-ink);
    font-size: 0.95rem;
    line-height: 1.65;
  }

  /* Summary box */
  .summary-box {
    background: var(--color-primary-muted);
    border-left: 4px solid var(--color-primary);
    border-radius: 0 10px 10px 0;
    padding: 1.5rem 1.75rem;
    margin-bottom: 2.5rem;
  }
  .summary-label {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
  }
  .summary-box p {
    margin: 0;
    color: var(--color-ink);
    font-size: 0.9375rem;
    line-height: 1.7;
  }
  .summary-box ul {
    margin: 0.5rem 0 0;
    padding-left: 1.25rem;
    color: var(--color-ink);
  }
  .summary-box li {
    font-size: 0.9375rem;
    line-height: 1.6;
    margin-bottom: 0.35rem;
  }

  /* FAQ accordion */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
  }
  .faq-item {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    overflow: hidden;
    background: var(--color-surface-elevated);
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .faq-item summary {
    padding: 1rem 1.25rem;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-ink);
    cursor: pointer;
    list-style: none;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: background 0.15s, color 0.15s;
    position: relative;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: '+';
    font-size: 1.25rem;
    color: var(--color-accent);
    flex-shrink: 0;
  }
  .faq-item[open] summary::after { content: '−'; }
  .faq-item summary:hover {
    background: var(--color-accent-muted);
    color: var(--color-accent);
  }
  .faq-item summary::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 3px;
    background: transparent;
    transition: background 0.15s;
  }
  .faq-item summary:hover::before,
  .faq-item[open] summary::before {
    background: var(--color-accent);
  }
  .faq-item[open] {
    border-color: rgba(242,101,34,0.35);
    box-shadow: 0 6px 20px rgba(242,101,34,0.08);
  }
  .faq-item[open] summary {
    background: var(--color-accent-muted);
    color: var(--color-accent);
  }
  .faq-item .faq-answer {
    padding: 0.75rem 1.25rem 1rem;
    font-size: 0.9375rem;
    color: var(--color-ink-muted);
    line-height: 1.7;
  }
  .faq-item .faq-answer p { margin: 0 0 0.5rem; }
  .faq-item .faq-answer p:last-child { margin: 0; }

  /* Pro-tip / callout */
  .pro-tip {
    background: #f0fdf4;
    border-left: 4px solid #10b981;
    border-radius: 0 8px 8px 0;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
    font-size: 0.9375rem;
    color: #064e3b;
    line-height: 1.65;
  }
  .warning-box {
    background: #fffbeb;
    border-left: 4px solid #f59e0b;
    border-radius: 0 8px 8px 0;
    padding: 1rem 1.25rem;
    margin: 1.25rem 0;
    font-size: 0.9375rem;
    color: #78350f;
    line-height: 1.65;
  }

  /* Sources section */
  .sources-list {
    list-style: none;
    padding: 0;
    margin: 1rem 0;
  }
  .sources-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.9rem;
    line-height: 1.55;
  }
  .sources-list li:last-child { border-bottom: none; }

  @media (max-width: 1024px) {
    .article-body { grid-template-columns: 1fr; }
    .toc-sidebar { position: static; }
  }
  @media (max-width: 768px) {
    .article-hero { padding: 2.5rem 0 2rem; }
  }
</style>
