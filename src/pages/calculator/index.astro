---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Section8Calculator from '../../components/Section8Calculator.astro';
import { calcPath, guidesPath } from '../../lib/i18n';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebApplication',
  name: 'Section 8 Housing Calculator',
  applicationCategory: 'FinanceApplication',
  operatingSystem: 'Any',
  offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  description:
    'Estimate Section 8 Housing Choice Voucher eligibility and monthly assistance by ZIP, city, county, and household income.',
};
---

<BaseLayout
  title="Section 8 Calculator by ZIP — Eligibility & Rent Estimate"
  description="Use our Section 8 calculator: enter ZIP to confirm city and county, then estimate voucher eligibility, income limits, and monthly housing assistance."
  canonicalPath={calcPath('en')}
  lang="en"
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </Fragment>

  <section class="calc-page-intro">
    <div class="container">
      <p class="calc-step-label">Step 1 of 3</p>
      <h1 class="font-display">Federal-style Section 8 estimate</h1>
      <p>
        ZIP-first lookup, HUD income limits, and Fair Market Rent — the same building blocks housing authorities use for voucher math.
      </p>
    </div>
  </section>

  <Section8Calculator lang="en" />

  <section class="container calc-how-it-works" style="padding-bottom: 4rem;">
    <div class="card">
      <h2 class="home-section-title">How this estimate works</h2>
      <ol>
        <li><strong>ZIP</strong> resolves your city and county (Census/FCC geography).</li>
        <li><strong>HUD income limits</strong> determine very low / low income eligibility.</li>
        <li><strong>Fair Market Rent</strong> sets the payment standard (we use 100% FMR unless your PHA publishes otherwise).</li>
        <li><strong>Total Tenant Payment</strong> is the greater of 30% of adjusted income, 10% of gross income, or $50 minimum.</li>
        <li><strong>Maximum subsidy</strong> = payment standard minus your tenant payment.</li>
      </ol>
      <p>
        Read more in our <a href={`${guidesPath('en')}how-section-8-housing-works/`}>how Section 8 works</a> guide or
        <a href={`${guidesPath('en')}section-8-income-limits-explained/`}>income limits explained</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .calc-how-it-works {
    margin-top: 2rem;
  }
</style>
