---
import BlogArticleLayout, { type BlogTocItem } from '../../../components/BlogArticleLayout.astro';
import { getEntry, render } from 'astro:content';

const entry = await getEntry('blog-es', 'section-8-lista-espera-2026');
if (!entry) throw new Error('Blog entry section-8-lista-espera-2026 not found');

const { Content } = await render(entry);
const { title, description, pubDate, tags, image } = entry.data;

const slugPath = '/es/blog/section-8-lista-espera-2026';
const site = Astro.site?.href?.replace(/\/$/, '') ?? 'https://section8calculator.com';
const pageUrl = `${site}${slugPath}`;

const publishDate = pubDate.toISOString().slice(0, 10);
const updatedDate = entry.data.updatedDate
  ? entry.data.updatedDate.toISOString().slice(0, 10)
  : publishDate;

const wordCount = (entry.body ?? '').trim().split(/\s+/).filter(Boolean).length;
const readingTime = `${Math.max(1, Math.ceil(wordCount / 200))} min de lectura`;

const tocItems: BlogTocItem[] = [
  { href: '#resumen-rápido-cómo-funciona-section-8-en-2026', label: 'Cómo funciona Section 8' },
  { href: '#cómo-funcionan-las-listas-de-espera-de-section-8-en-2026', label: 'Listas de espera' },
  { href: '#reglas-clave-de-elegibilidad-de-section-8-en-2026', label: 'Reglas de elegibilidad' },
  { href: '#preferencias-quién-avanza-en-la-lista-más-rápido', label: 'Preferencias' },
  { href: '#qué-estados-y-regiones-tienen-más-disponibilidad', label: 'Disponibilidad por estado' },
  { href: '#cómo-encontrar-listas-de-espera-abiertas-de-section-8-en-2026', label: 'Encontrar listas abiertas' },
  { href: '#cómo-proteger-su-lugar-en-la-lista-de-espera', label: 'Proteger su lugar' },
  { href: '#preguntas-frecuentes-section-8-en-2026', label: 'Preguntas frecuentes' },
  { href: '#estrategia-práctica-cómo-mejorar-sus-probabilidades-en-2026', label: 'Mejorar sus probabilidades' },
  { href: '#fuentes', label: 'Fuentes' },
];

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: title,
  description,
  image: image ? [`${site}${image}`] : [],
  datePublished: publishDate,
  dateModified: updatedDate,
  inLanguage: 'es',
  author: {
    '@type': 'Organization',
    name: 'Section 8 Calculator',
    url: site,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Section 8 Calculator',
    url: site,
    logo: { '@type': 'ImageObject', url: `${site}/favicon.svg` },
  },
  mainEntityOfPage: { '@type': 'WebPage', '@id': pageUrl },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: '¿Cuánto dura la lista de espera de Section 8 en 2026?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Depende mucho de dónde solicite. Algunos estados y grandes metrópolis tienen esperas promedio de tres a siete años, mientras que ciudades más pequeñas y PHAs rurales a veces ubican familias dentro de meses a un par de años.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Qué estados tienen la mejor disponibilidad de Section 8?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Mercados más pequeños en el Medio Oeste, Sur y Oeste rural tienden a tener más listas abiertas y tiempos de espera más cortos. Estados como Georgia, partes de Texas y algunos estados de las llanuras muestran más aperturas.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Puedo solicitar Section 8 en más de una ciudad o estado?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Sí. La guía de HUD y grupos de asistencia legal notan que puede solicitar en múltiples PHAs. Las preferencias de residencia local pueden poner a solicitantes no locales más abajo en la lista.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Quién califica para Section 8 en 2026?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Ingreso del hogar por debajo del 50% del ingreso mediano del área, con la mayoría de vouchers reservados para los que están bajo el 30% del AMI. Al menos un miembro del hogar debe tener ciudadanía o estatus migratorio elegible.',
      },
    },
    {
      '@type': 'Question',
      name: '¿Cómo solicito Section 8 en 2026?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Solicita a través de una PHA local, no directamente a HUD. La mayoría de las agencias ahora usan portales en línea. Cuando la lista está cerrada, debe esperar a que la PHA anuncie una nueva apertura.',
      },
    },
  ],
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${site}/es/` },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${site}/es/blog/` },
    { '@type': 'ListItem', position: 3, name: 'Listas de espera Section 8 2026', item: pageUrl },
  ],
};
---

<BlogArticleLayout
  title={title}
  description={description}
  canonical={slugPath}
  lang="es"
  author="Equipo Section 8 Calculator"
  authorTitle="Editorial"
  readingTime={readingTime}
  updatedDate={updatedDate}
  tags={tags}
  tocItems={tocItems}
>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(articleSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(faqSchema)} />
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(breadcrumbSchema)} />
  <Content />
</BlogArticleLayout>
