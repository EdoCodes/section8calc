---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Contact Us | Section 8 Calculator"
  description="Get in touch with the Section 8 Calculator team for questions, feedback, partnerships, or corrections."
>
  <article class="container" style="padding: 2.5rem 0 4rem; max-width: 42rem;">
    <h1 class="contact-title">Contact Us</h1>

    <p class="contact-intro">
      Have a question, found an error, or want to suggest an improvement? We'd love to hear
      from you. Section 8 Calculator is a small, independent project, and we read every message.
    </p>

    <div class="contact-info-grid">
      <div class="contact-info-card">
        <h3>Before You Write</h3>
        <ul>
          <li><strong>"Can you help me apply for Section 8?"</strong> — We are not a PHA and cannot process applications. Please contact your <a href="https://www.hud.gov/program_offices/public_indian_housing/pha/contacts">local Public Housing Authority</a> directly.</li>
          <li><strong>"Why doesn't my city show the right data?"</strong> — Our estimates are based on HUD's published income limits and Fair Market Rents. Include your ZIP code so we can investigate.</li>
          <li><strong>"Can I link to your site?"</strong> — Yes! We encourage housing counselors, nonprofits, and media to link to our resources.</li>
        </ul>
      </div>
      <div class="contact-info-card">
        <h3>Response Time</h3>
        <p>
          We typically respond within <strong>1–3 business days</strong>. We cannot provide
          individual housing advice or eligibility determinations — for that, please contact
          your local PHA.
        </p>
      </div>
    </div>

    <div class="contact-form-wrap">
      <h2>Send Us a Message</h2>

      <form
        name="contact"
        method="POST"
        data-netlify="true"
        netlify-honeypot="bot-field"
        action="/contact/?success=true"
        class="contact-form"
      >
        <input type="hidden" name="form-name" value="contact" />
        <p class="hidden" style="display:none;">
          <label>Don't fill this out: <input name="bot-field" /></label>
        </p>

        <div class="form-row">
          <div class="form-group">
            <label for="name">Your Name <span class="required">*</span></label>
            <input type="text" id="name" name="name" required placeholder="John Doe" />
          </div>
          <div class="form-group">
            <label for="email">Your Email <span class="required">*</span></label>
            <input type="email" id="email" name="email" required placeholder="john@example.com" />
          </div>
        </div>

        <div class="form-group">
          <label for="subject">Subject <span class="required">*</span></label>
          <select id="subject" name="subject" required>
            <option value="" disabled selected>Select a topic…</option>
            <option value="general">General Question</option>
            <option value="data-error">Data Error / Correction</option>
            <option value="feedback">Feedback / Suggestion</option>
            <option value="media">Media / Press Inquiry</option>
            <option value="partnership">Partnership / Collaboration</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message">Message <span class="required">*</span></label>
          <textarea id="message" name="message" rows="6" required placeholder="Tell us what's on your mind…"></textarea>
        </div>

        <button type="submit" class="btn btn-primary contact-submit">Send Message</button>
      </form>

      <div id="success-message" class="contact-success" style="display: none;">
        <div class="success-icon">&#10003;</div>
        <h3>Message Sent!</h3>
        <p>Thank you for reaching out. We'll get back to you within 1–3 business days.</p>
        <a href="/">← Back to Home</a>
      </div>
    </div>

    <p style="margin-top: 2rem; font-size: 0.9rem; color: var(--color-ink-muted);">
      <a href="/about/">About us</a> · <a href="/disclaimer/">Disclaimer</a>
    </p>
  </article>
</BaseLayout>

<style>
  .contact-title {
    font-size: 2rem;
    margin: 0 0 0.75rem;
  }

  .contact-intro {
    font-size: 1.05rem;
    color: var(--color-ink-muted);
    line-height: 1.6;
    margin: 0 0 1.75rem;
  }

  .contact-info-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  @media (min-width: 600px) {
    .contact-info-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .contact-info-card {
    background: var(--color-surface, #fff);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 12px;
    padding: 1.25rem 1.35rem;
  }

  .contact-info-card h3 {
    font-size: 0.95rem;
    font-weight: 700;
    margin: 0 0 0.6rem;
    color: var(--color-ink);
  }

  .contact-info-card ul {
    padding-left: 1.15rem;
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
  }

  .contact-info-card ul li {
    margin-bottom: 0.5rem;
  }

  .contact-info-card p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.55;
    color: var(--color-ink-muted);
  }

  .contact-form-wrap {
    background: var(--color-surface, #fff);
    border: 1px solid var(--color-border, #e5e7eb);
    border-radius: 14px;
    padding: 1.75rem 1.75rem 2rem;
  }

  .contact-form-wrap h2 {
    font-size: 1.25rem;
    margin: 0 0 1.25rem;
    color: var(--color-ink);
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  @media (min-width: 480px) {
    .form-row {
      grid-template-columns: 1fr 1fr;
    }
  }

  .form-group {
    display: flex;
    flex-direction: column;
    margin-bottom: 1rem;
  }

  .form-group label {
    font-size: 0.88rem;
    font-weight: 600;
    margin-bottom: 0.35rem;
    color: var(--color-ink);
  }

  .required {
    color: var(--color-accent);
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    padding: 0.6rem 0.8rem;
    font-size: 0.92rem;
    border: 2px solid var(--color-border, #d4d4d8);
    border-radius: 8px;
    background: #fff;
    color: var(--color-ink);
    font-family: inherit;
    transition: border-color 0.15s;
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(234, 127, 43, 0.12);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-submit {
    margin-top: 0.5rem;
    padding: 0.75rem 2rem;
    font-size: 1rem;
    cursor: pointer;
  }

  .contact-success {
    text-align: center;
    padding: 2rem 1rem;
  }

  .success-icon {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #22c55e;
    color: #fff;
    font-size: 1.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }

  .contact-success h3 {
    font-size: 1.25rem;
    margin: 0 0 0.5rem;
    color: var(--color-ink);
  }

  .contact-success p {
    color: var(--color-ink-muted);
    margin: 0 0 1rem;
  }
</style>

<script>
  if (window.location.search.includes('success=true')) {
    const form = document.querySelector('.contact-form') as HTMLElement;
    const msg = document.getElementById('success-message') as HTMLElement;
    if (form) form.style.display = 'none';
    if (msg) msg.style.display = 'block';
  }
</script>
