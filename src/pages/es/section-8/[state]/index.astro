---
export const prerender = false;

import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Section8StatePage from '../../../../components/Section8StatePage.astro';
import { getPlacesForState, getStateBySlug } from '../../../../lib/places';
import { statePath } from '../../../../lib/i18n';

const state = getStateBySlug(Astro.params.state!);
if (!state) return Astro.redirect('/es/section-8/');

Astro.response.headers.set('Cache-Control', 'public, max-age=86400, s-maxage=604800');
const places = getPlacesForState(state.abbr);
const title = `Section 8 en ${state.name} — ${state.placeCount.toLocaleString()} ciudades`;
const description = `Límites de ingreso Section 8 y estimaciones de voucher para ${state.placeCount.toLocaleString()} ciudades en ${state.name}.`;
---

<BaseLayout {title} {description} canonicalPath={statePath('es', state.slug)} lang="es">
  <Section8StatePage {state} {places} lang="es" />
</BaseLayout>
