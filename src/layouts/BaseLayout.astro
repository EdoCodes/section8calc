---
import '../styles/global.css';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import SiteAnalytics from '../components/SiteAnalytics.astro';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogType?: 'website' | 'article';
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  ogType = 'website',
} = Astro.props;

const site = Astro.site ?? new URL('https://section8calculator.com');
const canonical = new URL(canonicalPath, site).href;
const fullTitle = title.includes('Section 8') ? title : `${title} | Section 8 Calculator`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <GoogleAnalytics />
    <slot name="head" />
  </head>
  <body>
    <header class="site-header">
      <div class="container inner">
        <a class="logo" href="/">Section <span>8</span> Calculator</a>
        <nav class="nav" aria-label="Main">
          <a href="/calculator/" aria-current={Astro.url.pathname.startsWith('/calculator') ? 'page' : undefined}>Calculator</a>
          <a href="/section-8/" aria-current={Astro.url.pathname.startsWith('/section-8') ? 'page' : undefined}>By city</a>
          <a href="/guides/" aria-current={Astro.url.pathname.startsWith('/guides') ? 'page' : undefined}>Guides</a>
          <a class="btn btn-primary" href="/calculator/" data-analytics="cta_calculator_nav">Check eligibility</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          <strong>Disclaimer:</strong> This site provides educational estimates based on HUD income limits and Fair Market Rents.
          It is not affiliated with HUD or your local Public Housing Authority. Always apply through your PHA for official determinations.
        </p>
        <p>
          <a href="/calculator/">Section 8 calculator</a> ·
          <a href="/guides/">Housing guides</a>
        </p>
      </div>
    </footer>
    <SiteAnalytics />
  </body>
</html>
