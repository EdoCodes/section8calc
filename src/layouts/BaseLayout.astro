---
import '../styles/global.css';
import GoogleAnalytics from '../components/GoogleAnalytics.astro';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import SiteAnalytics from '../components/SiteAnalytics.astro';
import SiteLogoMark from '../components/SiteLogoMark.astro';
import {
  alternateLangPath,
  blogPath,
  calcPath,
  citiesPath,
  getSiteStrings,
  guidesPath,
  homePath,
  type Lang,
} from '../lib/i18n';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  ogType?: 'website' | 'article';
  lang?: Lang;
  /** Extra class on body (e.g. page-home for landing UX scale). */
  bodyClass?: string;
}

const {
  title,
  description,
  canonicalPath = Astro.url.pathname,
  ogType = 'website',
  lang = 'en',
  bodyClass = '',
} = Astro.props;

const s = getSiteStrings(lang);
const site = Astro.site ?? new URL('https://section8calculator.com');
const canonical = new URL(canonicalPath, site).href;
const fullTitle = title.includes('Section 8') || title.includes('Section8') || title.includes('Calculadora')
  ? title
  : `${title} | ${s.siteName}`;

const altPath = alternateLangPath(canonicalPath, lang);
const altCanonical = new URL(altPath, site).href;
const enCanonical = lang === 'en' ? canonical : altCanonical;
const esCanonical = lang === 'es' ? canonical : altCanonical;
---

<!doctype html>
<html lang={lang === 'es' ? 'es' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={enCanonical} />
    <link rel="alternate" hreflang="es" href={esCanonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{fullTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <GoogleAnalytics />
    <slot name="head" />
  </head>
  <body class:list={['bg-mesh', bodyClass]}>
    <header class="site-header site-header--glass">
      <div class="container inner">
        <a class="site-logo" href={homePath(lang)}>
          <span class="site-logo__mark">
            <SiteLogoMark />
          </span>
          <span class="site-logo__text">
            <span class="site-logo__name">{s.siteName}</span>
            <span class="site-logo__tagline">{s.siteTagline}</span>
          </span>
        </a>
        <nav class="site-nav" aria-label="Main">
          <a href={citiesPath(lang)} aria-current={Astro.url.pathname.includes('section-8') ? 'page' : undefined}>{s.navCities}</a>
          <a href={guidesPath(lang)} aria-current={Astro.url.pathname.includes('guides') || Astro.url.pathname.includes('guias') ? 'page' : undefined}>{s.navGuides}</a>
          <a href={blogPath(lang)} aria-current={Astro.url.pathname.includes('blog') ? 'page' : undefined}>{s.navBlog}</a>
          <LanguageSwitcher lang={lang} />
          <a class="btn btn-primary" href={calcPath(lang)} data-analytics="cta_calculator_nav">{s.navCta}</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-grid">
        <div class="footer-col">
          <p class="footer-brand">
            <strong>{s.siteName}</strong>
          </p>
          <p class="footer-tagline">{s.siteTagline}</p>
          <p class="footer-copy">&copy; {new Date().getFullYear()} Section 8 Calculator</p>
        </div>

        <div class="footer-col">
          <h4 class="footer-heading">{lang === 'es' ? 'Herramientas' : 'Tools'}</h4>
          <ul class="footer-links">
            <li><a href={calcPath(lang)}>{s.calcLink}</a></li>
            <li><a href={citiesPath(lang)}>{s.citiesLink}</a></li>
            <li><a href={guidesPath(lang)}>{s.guidesLink}</a></li>
            <li><a href={blogPath(lang)}>{s.blogLink}</a></li>
          </ul>
        </div>

        <div class="footer-col">
          <h4 class="footer-heading">{lang === 'es' ? 'Empresa' : 'Company'}</h4>
          <ul class="footer-links">
            <li><a href={lang === 'es' ? '/es/sobre-nosotros/' : '/about/'}>{lang === 'es' ? 'Sobre nosotros' : 'About Us'}</a></li>
            <li><a href={lang === 'es' ? '/es/contacto/' : '/contact/'}>{lang === 'es' ? 'Contáctenos' : 'Contact Us'}</a></li>
            <li><a href={lang === 'es' ? '/es/aviso-legal/' : '/disclaimer/'}>{lang === 'es' ? 'Aviso legal' : 'Disclaimer'}</a></li>
          </ul>
        </div>
      </div>

      <div class="container footer-bottom">
        <p>{s.footerDisclaimer}</p>
      </div>
    </footer>
    <SiteAnalytics />
  </body>
</html>
