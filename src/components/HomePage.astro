---
import { getCollection } from 'astro:content';
import {
  calcPath,
  getHomeStrings,
  guideSlugPath,
  type Lang,
} from '../lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const h = getHomeStrings(lang);
const rawGuides =
  lang === 'es'
    ? await getCollection('guides-es', ({ data }) => !data.draft)
    : await getCollection('guides', ({ data }) => !data.draft);
const guides = rawGuides
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 6);
---

<section class="home-hero">
  <div class="container">
    <p class="home-hero__domain">{h.domain}</p>
    <h1 class="home-hero__title">
      {h.heroLine1}
      <span class="home-hero__accent"> {h.heroAccent} </span>
      {h.heroLine2}
    </h1>
    <p class="home-hero__lead">{h.heroLead}</p>

    <form class="home-search" action={calcPath(lang)} method="get" id="home-zip-form">
      <div class="home-search__wrap">
        <span class="home-search__icon" aria-hidden="true">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="7"></circle>
            <path d="M20 20l-3-3" stroke-linecap="round"></path>
          </svg>
        </span>
        <input
          type="text"
          name="zip"
          inputmode="numeric"
          pattern="\d{5}"
          maxlength="5"
          placeholder={h.searchPlaceholder}
          aria-label={h.searchPlaceholder}
          required
        />
        <button type="submit" class="btn btn-primary">{h.searchButton}</button>
      </div>
    </form>
  </div>
</section>

<section class="container home-calc-panel">
  <ul class="home-calc-grid">
    {h.tools.map((tool) => (
      <li>
        <a class="home-calc-card" href={tool.href}>
          <span class={`home-calc-card__icon ${tool.iconClass}`} aria-hidden="true">{tool.emoji}</span>
          <h3>{tool.title}</h3>
          <p>{tool.subtitle}</p>
        </a>
      </li>
    ))}
  </ul>
</section>

<section class="container home-feature">
  <div class="home-feature__grid">
    <div class="card">
      <h2 class="home-section-title">{h.featureTitle1}</h2>
      <ul>
        {h.featureBody1.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
    <div class="card">
      <h2 class="home-section-title">{h.featureTitle2}</h2>
      <p>{h.featureBody2}</p>
      <p style="margin-top: 1rem;">
        <a href={h.tools[2].href}>{h.featureLink2}</a>
      </p>
    </div>
  </div>
</section>

{guides.length > 0 && (
  <section class="container" style="padding-bottom: 4rem;">
    <h2 class="home-section-title">{h.guidesTitle}</h2>
    <div class="guides-grid" style="margin-top: 1rem;">
      {guides.map((guide) => (
        <a class="guide-card" href={guideSlugPath(lang, guide.id)}>
          {guide.data.tags[0] && <span class="tag">{guide.data.tags[0]}</span>}
          <h2>{guide.data.title}</h2>
          <p>{guide.data.description}</p>
        </a>
      ))}
    </div>
  </section>
)}

<script>
  document.getElementById('home-zip-form')?.addEventListener('submit', (e) => {
    const form = e.currentTarget as HTMLFormElement;
    const zip = (new FormData(form).get('zip') as string)?.trim();
    if (zip && /^\d{5}$/.test(zip)) {
      e.preventDefault();
      const base = form.getAttribute('action') || '/calculator/';
      window.location.href = `${base}?zip=${zip}#section8-calculator`;
    }
  });
</script>
