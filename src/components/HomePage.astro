---
import { getCollection } from 'astro:content';
import CalcHowItWorks from './CalcHowItWorks.astro';
import CalculatorHero from './CalculatorHero.astro';
import HomeStateCityDirectory from './HomeStateCityDirectory.astro';
import Section8Calculator from './Section8Calculator.astro';
import { getHomeStrings, guideSlugPath, guidesPath, type Lang } from '../lib/i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const h = getHomeStrings(lang);
const rawGuides =
  lang === 'es'
    ? await getCollection('guides-es', ({ data }) => !data.draft)
    : await getCollection('guides', ({ data }) => !data.draft);
const guides = rawGuides.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<div class="home-page">
  <CalculatorHero lang={lang} />

  <div class="home-calculator-band">
    <Section8Calculator lang={lang} />
  </div>

  <CalcHowItWorks lang={lang} />

  {guides.length > 0 && (
    <section class="container container--wide home-guides" id="guides">
      <h2 class="home-section-title">{h.guidesTitle}</h2>
      <div class="guides-grid">
        {guides.map((guide) => (
          <a class="guide-card" href={guideSlugPath(lang, guide.id)}>
            {guide.data.tags[0] && <span class="tag">{guide.data.tags[0]}</span>}
            <h3>{guide.data.title}</h3>
            <p>{guide.data.description}</p>
          </a>
        ))}
      </div>
      <p class="home-guides__more">
        <a href={guidesPath(lang)}>{h.allGuides} →</a>
      </p>
    </section>
  )}

  <HomeStateCityDirectory
    lang={lang}
    title={h.browseByStateTitle}
    filterLabel={h.stateFilterLabel}
    filterPlaceholder={h.stateFilterPlaceholder}
    viewAllLabel={h.viewAllStates}
  />
</div>

<style>
  .home-page :global(.calc-hero) {
    padding-bottom: 1.5rem;
  }
  .home-calculator-band {
    margin-top: -3.25rem;
  }
  .home-calculator-band :global(.calc-shell) {
    margin-top: 0;
  }
  .home-guides {
    padding: 2.5rem 0 1rem;
  }
  .home-guides .guide-card h3 {
    font-size: 1.1rem;
    margin: 0 0 0.5rem;
  }
  .home-guides__more {
    margin: 1.25rem 0 0;
  }
</style>
