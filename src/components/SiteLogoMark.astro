---
/** Outline house with chimney + S8 inside — matches user-supplied icon */
---

<svg
  class="site-logo__svg"
  xmlns="http://www.w3.org/2000/svg"
  viewBox="0 0 64 64"
  fill="none"
  aria-hidden="true"
  focusable="false"
>
  <!-- Chimney -->
  <rect x="17" y="12" width="5.5" height="14" rx="1" fill="none" stroke="#002147" stroke-width="3.5" stroke-linejoin="round"></rect>

  <!-- Roof -->
  <path d="M8 30 32 10 56 30" stroke="#002147" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"></path>

  <!-- House body -->
  <path d="M14 28v22.5c0 1.1.9 2 2 2h32c1.1 0 2-.9 2-2V28" stroke="#002147" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"></path>

  <!-- Door -->
  <path d="M27 52.5V42c0-1.1.9-2 2-2h6c1.1 0 2 .9 2 2v10.5" stroke="#002147" stroke-width="3.5" stroke-linejoin="round"></path>

  <!-- S8 text -->
  <text
    x="32"
    y="37.5"
    text-anchor="middle"
    fill="#002147"
    font-family="DM Sans, Segoe UI, system-ui, sans-serif"
    font-size="13"
    font-weight="800"
    letter-spacing="-0.04em">S8</text>
</svg>
