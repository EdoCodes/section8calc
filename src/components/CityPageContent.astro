---
import { getCollection } from 'astro:content';
import type { Lang } from '../lib/i18n';
import { guideSlugPath, statePath } from '../lib/i18n';
import type { PlaceRecord, StateMeta } from '../lib/places';
import { getCityFaq, getCityPageCopy, getCityUiPaths } from '../lib/city-content';
import CityEnrichmentSection from './CityEnrichmentSection.astro';

interface Props {
  place: PlaceRecord;
  state: StateMeta;
  lang?: Lang;
}

const { place, state, lang = 'en' } = Astro.props;

const copy = getCityPageCopy(place, state, lang);
const faq = getCityFaq(place, state, lang);
const paths = getCityUiPaths(lang);

const allGuides =
  lang === 'es'
    ? (await getCollection('guides-es', ({ data }) => !data.draft)).sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
      )
    : (await getCollection('guides', ({ data }) => !data.draft)).sort(
        (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
      );
---

<article class="city-page container">
  <nav aria-label="Breadcrumb" class="breadcrumb">
    <a href={paths.cities}>{copy.breadcrumbAll}</a>
    <span aria-hidden="true"> / </span>
    <a href={statePath(lang, state.slug)}>{state.name}</a>
    <span aria-hidden="true"> / </span>
    <span>{copy.city}</span>
  </nav>

  <header class="city-page__hero">
    <h1 class="font-display">{copy.h1}</h1>
    <p class="meta">
      {copy.countyPhrase} · {state.name}
    </p>
    <p>{copy.programIntro}</p>
  </header>

  <CityEnrichmentSection stateSlug={state.slug} citySlug={place.slug} lang={lang} />

  <section class="card city-page__cta">
    <h2>{copy.ctaTitle}</h2>
    <p>{copy.calculatorPitch}</p>
    <a
      class="btn btn-primary"
      href={paths.calc}
      data-analytics="cta_calculator_city"
      data-analytics-city={copy.city}
      data-analytics-state={copy.stateAbbr}
    >
      {copy.ctaButton}
    </a>
  </section>

  <section class="city-page__section">
    <h2>{copy.voucherSection}</h2>
    <p>{copy.voucherExplain}</p>
    <p>{copy.waitingListNote}</p>
    <ul>
      <li><strong>{lang === 'es' ? 'Section 8 basado en proyecto' : 'Project-based Section 8'}</strong> — {copy.projectBased}</li>
      <li><strong>{lang === 'es' ? 'Vouchers HCV' : 'Tenant-based vouchers (HCV)'}</strong> — {copy.tenantBased}</li>
      <li><strong>{lang === 'es' ? 'Preferencias locales' : 'Local preferences'}</strong> — {copy.localPrefs}</li>
    </ul>
  </section>

  <section class="city-page__section">
    <h2>{copy.guidesSection}</h2>
    <p>{copy.guidesLead}</p>
    <div class="guides-grid">
      {allGuides.map((guide) => (
        <a class="guide-card" href={guideSlugPath(lang, guide.id)}>
          {guide.data.tags[0] && <span class="tag">{guide.data.tags[0]}</span>}
          <h3>{guide.data.title}</h3>
          <p>{guide.data.description}</p>
        </a>
      ))}
    </div>
    <p class="city-page__more-guides">
      <a href={paths.guides} data-analytics="cta_guides_index_from_city">{copy.allGuides}</a>
    </p>
  </section>

  <section class="city-page__section">
    <h2>{copy.applySection}</h2>
    <ol>
      <li>
        {lang === 'es' ? 'Confirme límites con la ' : 'Confirm income limits with the '}
        <a href={paths.calc} data-analytics="cta_calculator_city_inline">{lang === 'es' ? 'calculadora' : 'calculator'}</a>.
      </li>
      <li>
        {lang === 'es' ? 'Busque su PHA en el ' : 'Find your PHA via the '}
        <a href={copy.phaFinderUrl} rel="noopener noreferrer" target="_blank">{copy.phaDirectory}</a>
        ({copy.stateName} / {copy.countyPhrase}).
      </li>
      <li>{copy.applySteps[2]}</li>
      <li>{copy.applySteps[3]}</li>
    </ol>
  </section>

  <section class="city-page__section city-page__faq">
    <h2>{copy.faqSection}</h2>
    {faq.map((item) => (
      <details class="faq-item">
        <summary>{item.question}</summary>
        <p>{item.answer}</p>
      </details>
    ))}
  </section>

  <footer class="city-page__footer">
    <a class="btn btn-secondary" href={statePath(lang, state.slug)}>
      {copy.moreCities}
    </a>
    <a
      class="btn btn-primary"
      href={paths.calc}
      data-analytics="cta_calculator_city_footer"
      data-analytics-city={copy.city}
      data-analytics-state={copy.stateAbbr}
    >
      {copy.calcFooter}
    </a>
  </footer>
</article>

<style>
  .city-page {
    padding: 2rem 0 4rem;
  }
  .city-page__hero h1 {
    margin-bottom: 0.5rem;
  }
  .city-page__section {
    margin-top: 2.5rem;
  }
  .city-page__section h2 {
    margin-bottom: 0.75rem;
  }
  .city-page__section h3 {
    font-size: 1.05rem;
    margin: 0 0 0.5rem;
  }
  .city-page__cta {
    margin-top: 1.5rem;
  }
  .city-page__cta h2 {
    margin-top: 0;
  }
  .city-page__more-guides {
    margin-top: 1rem;
  }
  .city-page__faq .faq-item {
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    margin-bottom: 0.65rem;
    background: var(--color-surface-elevated);
  }
  .city-page__faq summary {
    font-weight: 600;
    cursor: pointer;
  }
  .city-page__faq p {
    margin: 0.75rem 0 0;
    color: var(--color-ink-muted);
  }
  .city-page__footer {
    margin-top: 2.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .breadcrumb {
    font-size: 0.9rem;
    color: var(--color-ink-muted);
    margin-bottom: 1rem;
  }
  .meta {
    color: var(--color-ink-muted);
  }
</style>
